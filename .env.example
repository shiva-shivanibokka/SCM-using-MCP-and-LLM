# Pet Store SCM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.


# ── Database (PostgreSQL / Neon) ───────────────────────────────────────────
# The app reads from Postgres when this is set, else falls back to bundled CSVs.
# Create a free project at https://neon.tech and paste its connection string:
#   DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
# Then run once:  python db/load_to_postgres.py
DATABASE_URL=


# ── LLM Provider API Keys (BYOK) ───────────────────────────────────────────
# This app is bring-your-own-key: users enter their key in the UI, which always
# takes priority over anything set here. These slots are an optional local-dev
# fallback only. Leave them BLANK in production so each visitor uses their own.
# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Groq (free tier): https://console.groq.com
GROQ_API_KEY=
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── UI Defaults ────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6


# ── MCP Server ─────────────────────────────────────────────────────────────
# true = MCP runs inside the app process (recommended, no separate server)
# false = MCP runs as a separate HTTP server on MCP_PORT
BYPASS_MCP_HTTP=true
MCP_SERVER_URL=http://localhost:8000
MCP_PORT=8000
# Set a strong random token to protect /sse and /messages when BYPASS_MCP_HTTP=false.
MCP_AUTH_TOKEN=


# ── App Settings ───────────────────────────────────────────────────────────
LOGS_DIR=logs
PORT=7860


# ── SerpAPI (optional — enables Google Search in the web_search tool) ───────
# Falls back to DuckDuckGo if not set. https://serpapi.com/manage-api-key
SERPAPI_KEY=
