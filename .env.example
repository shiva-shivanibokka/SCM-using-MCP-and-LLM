# Pet Store SCM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# ── LLM Provider API Keys ──────────────────────────────────────────────────
# Fill in at least one. Keys typed in the UI always override what is set here.
# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (free tier): https://console.groq.com
GROQ_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── UI Defaults ────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-5


# ── MCP Server ─────────────────────────────────────────────────────────────
# true  = MCP runs inside the app process (recommended, no separate server needed)
# false = MCP runs as a separate HTTP server on MCP_PORT
BYPASS_MCP_HTTP=true
MCP_SERVER_URL=http://localhost:8000
MCP_PORT=8000
# Set a strong random token to protect the /sse and /messages endpoints
# when BYPASS_MCP_HTTP=false.  Leave blank to disable auth (local dev only).
MCP_AUTH_TOKEN=


# ── Local MySQL ────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=pet_store_scm


# ── Cloud MySQL (e.g. Railway) ─────────────────────────────────────────────
# Paste from Railway → MySQL service → Variables tab
MYSQL_CLOUD_HOST=
MYSQL_CLOUD_PORT=3306
MYSQL_CLOUD_USER=
MYSQL_CLOUD_PASSWORD=
MYSQL_CLOUD_DB=railway


# ── Local PostgreSQL ───────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DB=pet_store_scm


# ── Cloud PostgreSQL (e.g. Railway) ───────────────────────────────────────
# Paste from Railway → PostgreSQL service → Variables tab
PG_CLOUD_HOST=
PG_CLOUD_PORT=5432
PG_CLOUD_USER=postgres
PG_CLOUD_PASSWORD=
PG_CLOUD_DB=railway


# ── App Settings ───────────────────────────────────────────────────────────
LOGS_DIR=logs
PORT=7860


# ── SerpAPI (optional — enables Google Search in web_search tool) ─────────
# Falls back to DuckDuckGo if not set.
# https://serpapi.com/manage-api-key
SERPAPI_KEY=
